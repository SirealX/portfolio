---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 — Page Not Found | Cesar Luna</title>
  </head>
  <body class="bg-bg-primary text-txt-primary min-h-screen flex items-center justify-center overflow-hidden">

    <div class="relative z-10 text-center px-6 max-w-lg mx-auto">

      <p class="text-[10px] font-black uppercase tracking-[0.4em] text-accent mb-4">
        [ ERROR_CODE: 404 ]
      </p>

      <h1 class="text-[8rem] font-black tracking-tighter leading-none text-txt-primary/10 select-none mb-2">
        404
      </h1>

      <h2 class="text-3xl font-bold tracking-tight text-txt-primary mb-4">
        Page Not Found
      </h2>

      <p class="text-txt-secondary text-[15px] leading-relaxed mb-10">
        The route you requested doesn't exist or was moved.<br/>
        Head back to the portfolio.
      </p>

      <a
        href="/en/"
        class="inline-flex items-center gap-3 px-8 py-4 bg-accent text-bg-primary font-bold uppercase tracking-tighter rounded-full hover:scale-105 active:scale-95 transition-all shadow-[0_0_20px_rgba(6,182,212,0.3)]"
      >
        ← Return Home
      </a>

      <p class="mt-10 text-[10px] font-mono text-txt-secondary/40 uppercase tracking-widest">
        cesarluna-dev.vercel.app
      </p>
    </div>

  </body>
</html>
